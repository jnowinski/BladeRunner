# Twitter/X API Credentials
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Reddit API Credentials
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=YourBotName/1.0

# Bluesky Credentials
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Threads API Credentials (Optional)
THREADS_ACCESS_TOKEN=your_access_token_here

# SQLite Database Configuration
# Path to the SQLite database file (will be created automatically)
DB_PATH=data/scraper.db
